# 2. Найти слово
def task2_frequent_word():
    print("Задача 2. Самое часто встречающееся слово")
    list_of_words = ['hello', 'hello', 'hi', 'hello', 'hi', 'world']
    words = {}
    for word in list_of_words:
        words[word] = words.get(word, 0) + 1
    freq_word = max(words, key=words.get)
    print("Самое частотное слово:", freq_word)
    print("Количество повторений:", words[freq_word])
    print()

