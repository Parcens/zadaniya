# 4. Старший и младший
def task4_youngest_oldest():
    print("Задача 4. Старший и младший")
    friends = []
    friends_data = [
        ('Иван', 11),
        ('Саша', 12),
        ('Леша', 10),
        ('Маша', 15)
    ]
    for name, age in friends_data:
        friends.append({'name': name, 'age': age})
    
    youngest = min(friends, key=lambda x: x['age'])
    oldest = max(friends, key=lambda x: x['age'])
    print("Самый младший:", youngest['name'])
    print("Самый старший:", oldest['name'])
    print()

# 5. Еще немного о друзьях
def task5_avg_age_longest_name():
    print("Задача 5. Средний возраст и самое длинное имя")
    friends = []
    friends_data = [
        ('Иван', 12),
        ('Иннокентий', 20),
        ('Леша', 10),
        ('Александр', 25)
    ]
    for name, age in friends_data:
        friends.append({'name': name, 'age': age})
    
    total_age = sum(friend['age'] for friend in friends)
    avg_age = total_age / len(friends)
    longest_name = max(friends, key=lambda x: len(x['name']))
    print("Средний возраст:", avg_age)
    print("Самое длинное имя:", longest_name['name'])
    print()

# 6. Английский словарь
def task6_english_dict():
    print("Задача 6. Английский словарь")
    english_dict = {}
    translations = [
        ('apple', 'яблоко'),
        ('apple', 'яблочко'),
        ('book', 'книга'),
        ('book', 'книжка'),
        ('cat', 'кот'),
        ('cat', 'кошка'),
        ('cat', 'котёнок')
    ]
    
    for eng, rus in translations:
        if eng not in english_dict:
            english_dict[eng] = []
        english_dict[eng].append(rus)
    
    print("Английский словарь:")
    for eng, rus_list in english_dict.items():
        print(f"{eng}: {', '.join(rus_list)}")
    print()

