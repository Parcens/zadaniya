# Четное число
def isEven(x):
    return x % 2 == 0

print("isEven(10) =", isEven(10))
print("isEven(11) =", isEven(11))

# Сумма списка
def amountList(lst):
    amount = 0
    for x in lst:
        amount += x
    return amount

mylist = [1, 2, 4, 8, 16]
print("Сумма списка", mylist, "=", amountList(mylist))

# Фибоначчи
def fib(n):
    a, b = 0, 1
    if n == 0:
        return 0
    for i in range(1, n):
        a, b = b, a + b
    return b

print("fib(5) =", fib(5))
print("fib(10) =", fib(10))

# Факториал
def fact(n):
    result = 1
    while n > 1:
        result *= n
        n -= 1
    return result

print("fact(5) =", fact(5))
print("fact(10) =", fact(10))
