# 1. Площадь круга
print("Задача 1. Площадь круга")
def circle(radius):
    return 3.14 * radius * radius

print(circle(4))
print(circle(1))
print()

# 2. На три
print("Задача 2. Проверка деления на 3")
def three(number):
    return number % 3 == 0

print(three(4))
print(three(3))
print()

# 3. Максимум в списке
print("Задача 3. Максимум в списке")
def maxList(lst):
    if len(lst) == 0:
        return None
    max_val = lst[0]
    for item in lst:
        if item > max_val:
            max_val = item
    return max_val

mylist = [1, 3, 2]
print(maxList(mylist))
print()

# 4. Сколько четных
print("Задача 4. Количество четных элементов")
def evenCounter(lst):
    count = 0
    for item in lst:
        if item % 2 == 0:
            count += 1
    return count

mylist = [1, 10, 2, 4, 6]
evens = evenCounter(mylist)
print(evens)
print()

# 5. Уникальные
print("Задача 5. Уникальные элементы")
def unique(lst):
    result = []
    for item in lst:
        if item not in result:
            result.append(item)
    return result

mylist = [1, 1, 2, 1, 3, 2, 3]
print(unique(mylist))
print()

